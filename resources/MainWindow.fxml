                            <font><Font name="System Bold" size="14.0" /></font>
                        </Text>
                        <Button mnemonicParsing="false" onAction="#showRGBModified" prefWidth="100.0" text="RGB" GridPane.rowIndex="1" />
                        <Button mnemonicParsing="false" onAction="#showRedModified" prefWidth="100.0" text="Red" GridPane.rowIndex="2" />
                        <Button mnemonicParsing="false" onAction="#showGreenModified" prefWidth="100.0" text="Green" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Button mnemonicParsing="false" onAction="#showBlueModified" prefWidth="100.0" text="Blue" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                        <Button mnemonicParsing="false" onAction="#showYModified" prefWidth="100.0" text="Y" GridPane.rowIndex="3" />
                        <Button mnemonicParsing="false" onAction="#showCbModified" prefWidth="100.0" text="Cb" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Button mnemonicParsing="false" onAction="#showCrModified" prefWidth="100.0" text="Cr" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                    </children>
