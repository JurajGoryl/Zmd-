                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Encode" GridPane.columnSpan="2">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Text>
                        <Button fx:id="buttonToYCbCr" maxWidth="1.797" mnemonicParsing="false" onAction="#convertToYCbCr" text="RGB -> YCbCr" GridPane.rowIndex="1" />
                        <Button fx:id="buttonSample" maxWidth="1.797" mnemonicParsing="false" onAction="#sample" text="Down Sample" GridPane.rowIndex="2" />
                        <Button fx:id="buttonTransform" maxWidth="1.797" mnemonicParsing="false" onAction="#transform" text="Transform" GridPane.rowIndex="3" />
                        <Button fx:id="buttonQuantize" maxWidth="1.797" mnemonicParsing="false" onAction="#quantize" text="Quantize" GridPane.rowIndex="4" />
                        <ComboBox fx:id="sampling" maxWidth="1.797" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <HBox alignment="CENTER" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <children>
                                <ComboBox fx:id="transformType" prefWidth="150.0" />
                                <Spinner fx:id="transformBlock" prefWidth="70.0" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <children>
                                <Slider fx:id="quantizeQuality" prefWidth="200.0" showTickLabels="true" />
                                <TextField fx:id="quantizeQualityField" prefWidth="50.0" />
                            </children>
                        </HBox>
                    </children>
                    <padding><Insets left="5.0" right="5.0" /></padding>
                </GridPane>

                <GridPane hgap="5.0" styleClass="background" vgap="5.0">
                    <columnConstraints>
                        <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" percentWidth="40.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Decode" GridPane.columnSpan="2">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Text>
                        <Button fx:id="buttonInverseQuantize" maxWidth="1.797" mnemonicParsing="false" onAction="#inverseQuantize" text="IQuantize" GridPane.rowIndex="1" />
                        <Button fx:id="buttonInverseTransform" maxWidth="1.797" mnemonicParsing="false" onAction="#inverseTransform" text="ITransform" GridPane.rowIndex="2" />
                        <Button fx:id="buttonInverseSample" maxWidth="1.797" mnemonicParsing="false" onAction="#inverseSample" text="Over Sample" GridPane.rowIndex="3" />
                        <Button fx:id="buttonInverseToRGB" maxWidth="1.797" mnemonicParsing="false" onAction="#convertToRGB" text="YCbCr -> RGB" GridPane.rowIndex="4" />
                    </children>
                    <padding><Insets left="5.0" right="5.0" /></padding>
                </GridPane>

                <GridPane hgap="5.0" styleClass="background">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Objective quality" GridPane.columnSpan="2" GridPane.halignment="CENTER">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Text>
                        <Button mnemonicParsing="false" onAction="#countQuality" prefWidth="100.0" text="Count" GridPane.rowIndex="1" GridPane.rowSpan="4" GridPane.halignment="CENTER"/>
                        <Text text="PSNR" GridPane.rowIndex="1" />
                        <TextField fx:id="qualityPSNR" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Text text="MSE" GridPane.rowIndex="2" />
                        <TextField fx:id="qualityMSE" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Text text="MAE" GridPane.rowIndex="3" />
                        <TextField fx:id="qualityMAE" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Text text="SAE" GridPane.rowIndex="4" />
                        <TextField fx:id="qualitySAE" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                    <padding><Insets left="5.0" right="5.0" /></padding>
                </GridPane>

                <GridPane alignment="CENTER" hgap="5.0" styleClass="background" vgap="5.0">
                    <columnConstraints>
                        <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" minWidth="10.0" percentWidth="35.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Watermarking" GridPane.columnSpan="2" GridPane.halignment="CENTER">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Text>
                        <HBox alignment="CENTER" spacing="10.0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                            <children>
                                <Button mnemonicParsing="false" onAction="#loadWatermark" prefWidth="130.0" text="Load Watermark" />
                                <Button mnemonicParsing="false" onAction="#runFinalTest" prefWidth="130.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Run Final Test" />
                            </children>
                        </HBox>
                        
                        <Text text="LSB h (0-7):" GridPane.rowIndex="2" />
                        <HBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <Slider fx:id="lsbHSlider" max="7" min="0" showTickLabels="true" HBox.hgrow="ALWAYS" />
                            <TextField fx:id="lsbHField" prefWidth="45.0" />
                        </HBox>

                        <Text text="DCT h (robust):" GridPane.rowIndex="3" />
                        <HBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <Slider fx:id="dctHSlider" max="100" min="0" showTickLabels="true" HBox.hgrow="ALWAYS" />
                            <TextField fx:id="dctHField" prefWidth="45.0" />
                        </HBox>

                        <Text text="Test Block Size:" GridPane.rowIndex="4" />
                        <Spinner fx:id="watermarkBlock" prefWidth="100.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                    <padding><Insets left="5.0" right="5.0" /></padding>
                </GridPane>

                <GridPane alignment="CENTER" hgap="5.0" styleClass="background" vgap="5.0">
                    <columnConstraints>
                        <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <children>
